ENVIRONMENT = local

API_ROUTE = http://localhost:5000

# Cognito Configuration
COGNITO_USER_POOL_ID = eu-central-1_unKiHP6hh
COGNITO_CLIENT_ID= ...
COGNITO_DOMAIN_PREFIX = ...
AWS_COGNI_CLIENT_SECRET = ...
FLASK_SECRET_KEY = ...

AWS_ACCESS_KEY_ID = ...
AWS_SECRET_ACCESS_KEY = ...
AWS_REGION = eu-central-1

# Alpaca API credentials (for market updates)
APCA_API_KEY_ID = ...
APCA_API_SECRET_KEY = ...

# Sentry DSN for error tracking
SENTRY_DSN = ...

# Sentiment API base through the /sentiment router (no trailing slash).
# Example local: http://127.0.0.1:8000/api/sentiment
SENTIMENT_API_URL = ...

# Database path configuration
# For local development: sqlite:///market.db
# For production (EC2 host with volume mount): sqlite:////data/market.db
DB_PATH = sqlite:///market.db
DB_MINUTE_PATH = sqlite:///market_minute.db


# DB_GRANULARITY can be 'day' or 'minute'; change it to switch databases
DB_GRANULARITY = day

# MINUTE_DATA_SOURCE defines the source of minute level data. either athena or 
# local DB. in production use athena.
MINUTE_DATA_SOURCE = local
#MINUTE_DATA_SOURCE = athena --> never locally!




#athena ; request these from admin.

DB_ATHENA_PATH=
ATHENA_BUCKET_BASE = 
GLUE_DB =
ATHENA_MINUTE_TABLE = 
